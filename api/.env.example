LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
# Optional: override the OAuth callback URL for production
# OAUTH_REDIRECT_URI=https://i3xscrape.jumpingcrab.com/auth/callback
# This will be auto-populated after OAuth login:
# LINKEDIN_ACCESS_TOKEN=

# Static file serving:
#   true  - always serve ../site/ (use when no nginx/web server)
#   false - never serve static files (use when nginx handles static content)
#   unset - auto-detect: serve if ../site/ directory exists
# SERVE_STATIC=false
